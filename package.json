{
  "name": "feedback-ai-bot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--require=./scripts/readlink-patch.cjs next dev",
    "build": "cross-env NODE_OPTIONS=--require=./scripts/readlink-patch.cjs next build",
    "start": "cross-env NODE_OPTIONS=--require=./scripts/readlink-patch.cjs next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
